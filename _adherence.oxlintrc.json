{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/report/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard))/i]",
        "message": "Font not provided by the design system. Available: Pretendard."
      },
      {
        "selector": "JSXOpeningElement[name.name='BorderItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|key|ref|className|style|children)$/]",
        "message": "<BorderItem> doesn't accept that prop. Declared props: title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GridCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|title|eg|children|dark|bordered|key|ref|className|style|children)$/]",
        "message": "<GridCard> doesn't accept that prop. Declared props: tag, title, eg, children, dark, bordered."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroupHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<GroupHeader> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LabelRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<LabelRow> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberedCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:num|title|children|note|pending|variant|key|ref|className|style|children)$/]",
        "message": "<NumberedCard> doesn't accept that prop. Declared props: num, title, children, note, pending, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberedCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:bordered|thin)$/]",
        "message": "<NumberedCard> variant must be one of 'bordered' | 'thin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|light)$/]",
        "message": "<Tag> variant must be one of 'solid' | 'outline' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Tag> size must be one of 'md' | 'sm'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "BorderItem": {
        "replaces": []
      },
      "Callout": {
        "replaces": []
      },
      "GridCard": {
